# ================================================================
# .env.docker.example — Copia este archivo a .env en el VPS
# Comando: cp .env.docker.example .env
# ================================================================

# Nombre de la app (aparece en emails, título del navegador, etc.)
APP_NAME="Inmobiliaria 365"

# Siempre "production" en el VPS. Nunca "local".
APP_ENV=production

# Se genera automático al levantar el contenedor por primera vez.
# Si necesitas generarla manualmente:
#   docker compose exec app php artisan key:generate --show
# Pega el resultado aquí con el formato: base64:XXXXX...
APP_KEY=base64:CHANGE_ME

# En producción siempre false. Si lo dejas true expones errores al público.
APP_DEBUG=false

# Tu dominio exacto con https. Sin barra al final.
APP_URL=https://inmobiliaria.acmanalytics.online

# Zona horaria del servidor. Lista completa: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=America/Caracas

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_VE

APP_MAINTENANCE_DRIVER=file

# Número de rondas de encriptación de contraseñas. 12 es el estándar seguro.
# Más alto = más seguro pero más lento. No cambiar salvo necesidad.
BCRYPT_ROUNDS=12

# ── Trusted Proxies ───────────────────────────────────────────
# OBLIGATORIO con Nginx Proxy Manager.
# NPM termina el SSL y reenvía como HTTP interno. Sin este valor
# Laravel no detecta que la conexión es HTTPS y rompe los redirects,
# las URLs de assets y las cookies seguras.
# El * significa "confiar en cualquier proxy", que es correcto
# porque MySQL y Redis están en una red Docker privada sin acceso externo.
TRUSTED_PROXIES=*

# ── Logs ──────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
# En producción usar "error" para no llenar el disco con logs de debug.
# Opciones: debug | info | warning | error | critical
LOG_LEVEL=error

# ── Base de datos MySQL ───────────────────────────────────────
DB_CONNECTION=mysql

# NO cambiar. "mysql" es el nombre del contenedor en docker-compose.yml.
# Docker resuelve ese nombre automáticamente dentro de la red interna.
DB_HOST=mysql
DB_PORT=3306

# Nombre de la base de datos que se creará automáticamente al iniciar MySQL.
# Puedes usar el que quieras, ej: inmobiliaria_prod, crm_365, etc.
DB_DATABASE=inmobiliaria_db

# Usuario de la base de datos (NO usar root para la app, es mala práctica).
# MySQL creará este usuario automáticamente con los permisos correctos.
DB_USERNAME=inmobiliaria_user

# Contraseña del usuario DB_USERNAME. Usa una contraseña fuerte.
# Ejemplo de contraseña fuerte: Inm0b!L1ar1a_2026#Prod
DB_PASSWORD=CHANGE_DB_PASSWORD

# Contraseña del usuario ROOT de MySQL. Solo se usa internamente por Docker.
# La app nunca usa root. Guárdala en un lugar seguro.
# Ejemplo: R00t_MySQL_S3cur3!2026
DB_ROOT_PASSWORD=CHANGE_ROOT_PASSWORD

# ── Redis ─────────────────────────────────────────────────────
# phpredis es la extensión C de Redis, más rápida que predis (PHP puro).
REDIS_CLIENT=phpredis

# NO cambiar. "redis" es el nombre del contenedor en docker-compose.yml.
REDIS_HOST=redis
REDIS_PORT=6379

# Contraseña de Redis. El contenedor arranca con --requirepass usando este valor.
# Ejemplo: R3d1s_S3cur3!2026
REDIS_PASSWORD=CHANGE_REDIS_PASSWORD

# ── Sesiones, Caché y Colas → Redis ──────────────────────────
# Usar Redis para sesiones es más rápido que la base de datos
# y permite escalar horizontalmente si en el futuro tienes varios servidores.
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Encripta el contenido de la cookie de sesión en el servidor.
SESSION_ENCRYPT=true

# Nombre de la cookie. Cámbialo si tienes otra app Laravel en el mismo dominio.
SESSION_COOKIE=inmobiliaria_session

# true = la cookie solo se envía por HTTPS. Obligatorio en producción.
SESSION_SECURE_COOKIE=true

# Caché en Redis. Mucho más rápido que guardarla en la base de datos.
CACHE_STORE=redis

# Colas en Redis. Los jobs (emails, notificaciones, etc.) se procesan en background.
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log

# "local" guarda los archivos subidos en storage/app/public dentro del contenedor.
# El volumen Docker app_storage los persiste entre reinicios.
FILESYSTEM_DISK=local

# ── Correo ────────────────────────────────────────────────────
# Opciones de MAIL_MAILER: smtp | mailgun | ses | log (solo para pruebas)
# Para pruebas sin configurar correo real, cambia MAIL_MAILER=log
# y los emails se guardarán en storage/logs en lugar de enviarse.
MAIL_MAILER=smtp

# Ejemplos de proveedores:
#   Gmail:      smtp.gmail.com  / puerto 587 / tls
#   Brevo:      smtp-relay.brevo.com / puerto 587 / tls
#   Mailgun:    smtp.mailgun.org / puerto 587 / tls
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=587
MAIL_USERNAME=tu@email.com
MAIL_PASSWORD=CHANGE_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@inmobiliaria.acmanalytics.online"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ──────────────────────────────────────────────────────
# Variable disponible en el frontend (Vue/JS). No cambiar.
VITE_APP_NAME="${APP_NAME}"
