# ==============================================
# Environment Variables - Producción
# Copiar este archivo a .env.production y completar
# ==============================================

APP_NAME="Inmobiliaria 365Soft"
APP_ENV=production
APP_KEY=base64:GENERAR_NUEVA_KEY
APP_DEBUG=false
APP_URL=https://inmobiliaria.acmanalytics.com
# Cambiar al subdominio que se usará

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ==============================================
# BASE DE DATOS
# ==============================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=inmobiliaria_365soft
DB_USERNAME=inmobiliaria_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# Root password para MySQL (solo Docker)
MYSQL_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_ROOT

# ==============================================
# CACHE & SESSION
# ==============================================
CACHE_DRIVER=redis
SESSION_DRIVER=database
QUEUE_CONNECTION=redis

# ==============================================
# REDIS
# ==============================================
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# ==============================================
# LOGGING
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ==============================================
# CORREO
# ==============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@acmanalytics.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# API EXTERNA (opcional)
# ==============================================
EXTERNAL_API_URL=https://fifusa.site/api/v1/products
EXTERNAL_API_KEY=68d382c6-63fb-4736-9669-f4e230efb2e1
EXTERNAL_API_CACHE_DURATION=300
EXTERNAL_API_TIMEOUT=30
